events {
    worker_connections  1024;
}

http {
    include       mime.types; # 包含 MIME 类型映射

    # WebSocket / SSE 连接升级映射
    map $http_upgrade $connection_upgrade {
        default upgrade;
        ''      '';
    }

    # HTTPS 反代入口
    # 监听 :5212 → 静态文件优先（assets/dist）→ 回退 :5213
    server {
        listen 5212 ssl;
        # listen 5212 quic;
        http2 on;
        server_name _;

        access_log off; # 关闭访问日志，防止硬盘爆炸

        # ── TLS ──────────────────────────
        ssl_certificate     certs/domain.pem;
        ssl_certificate_key certs/domain.key;
        ssl_protocols       TLSv1.2 TLSv1.3;
        ssl_session_cache   shared:SSL:10m;
        ssl_session_timeout 5m;

        # ── HTTP/3 通告 ──────────────────
        # add_header Alt-Svc 'h3=":5212"' always;

        # ── 请求限制 ────────────────────
        client_max_body_size        100m;
        client_header_buffer_size   4k;
        large_client_header_buffers 4 64k;

        # ── HTTP 误连 497 → HTTPS ───────
        error_page 497 https://$host:$server_port$request_uri;

        # ── 静态文件（预压缩优先）───────
        root assets/dist;
        brotli_static on;
        gzip_static   on;

        # ── 动态 gzip（API 响应兜底）────
        gzip            on;
        gzip_proxied    any;
        gzip_types      text/plain text/css application/javascript application/json application/xml;
        gzip_comp_level 5;
        gzip_min_length 1k;

        location / {
            try_files $uri $uri.html $uri/ @backend;
        }

        location @backend {
            proxy_pass http://127.0.0.1:5213;

            # 基础头
            proxy_set_header Host              $host;
            proxy_set_header X-Real-IP         $remote_addr;
            proxy_set_header X-Forwarded-For   $remote_addr;
            proxy_set_header X-Forwarded-Proto $scheme;

            # WebSocket + SSE 支持
            proxy_http_version      1.1;
            proxy_set_header Upgrade    $http_upgrade;
            proxy_set_header Connection $connection_upgrade;

            # 全双工流式传输
            proxy_request_buffering off;
            proxy_buffering         off;

            # 长连接超时
            proxy_read_timeout 60s;
            proxy_send_timeout 60s;
        }
    }
}