server:
  auth_key: ur_auth_key
  port: 5212
#  cert: "certs/domain.crt"
#  key: "certs/domain.key"
  public_address: https://example.com
  log_level: DEBUG

bing_crawler:
  use_jina_reader: false
  # 需要手动下载geckodriver
  geckodriver: geckodriver.exe

ncm:

bilibili:

VoiceRecognition:
  - type: azure
    key: xxx
    url: https://eastus.api.cognitive.microsoft.com/speechtotext/transcriptions:transcribe?api-version=2025-10-15
  - type: aliyun
    model: "paraformer-v2"
    key: sk-xxx

ocr:
  # 需要umi-ocr
  umi_ocr_endpoint: "http://127.0.0.1:1224/api/ocr"

link:

invite:
  # https://developers.cloudflare.com/turnstile/get-started/?preferred-color-scheme=dark#existing-sites
  turnstile-secret: ""
  invite-code-key: super_duper_SECRET_key_do_not_share

webchat:
  default-model: "deepseek-chat"
  default-vision-model: "qwen3.5-plus" # 需要支持视觉输入
  title-model: "deepseek-chat"
  prompt_raw: |-
    你是**马莉雅**（*Maria*）。你是一位真诚且具备适配能力的人工智能协作伙伴，略带一丝风趣。你的目标是通过富有洞见、同时清晰简洁的回复，精准回应用户的真实需求。你的核心原则是在共情与坦诚之间找到平衡：以支持性、接地气的人工智能身份，真诚认可用户的感受；同时以友善同行而非刻板说教者的姿态，温和但直接地纠正明显的错误信息。细微调整你的语气、情绪和幽默感，以适配用户的沟通风格。

    ---

    **用户区域**

    这是用户区域，根据用户自定义。你可以在回复中适度借鉴和当前问题相关的记忆，提供个性化对话体验。

    **用户记忆**：[时间戳] 记忆内容
    {memory_block}

    **定时任务**：[任务名称]：触发方式 触发时间
    {task_block}

    ---

    **现在的时间**：{time}
    **用户环境**：{device}

    ---
  models:
    deepseek-v4-flash:
      desc: "Deepseek V4 Flash"
      api_key: sk-xxx
      thinking-extra-body:
        'false':
          thinking:
            type: disabled
        'true':
          thinking:
            type: enabled
      url: https://api.deepseek.com/
    kimi-k2.6:
      desc: "Kimi K2.6"
      api_key: sk-xxx
      vision: true
      thinking-extra-body:
        'false':
          thinking:
            type: disabled
        'true':
          thinking:
            type: enabled
            keep: all
      url: https://api.moonshot.cn/v1
    qwen3.6-plus:
      desc: "Qwen3.6 Plus"
      api_key: sk-xxx
      vision: true
      thinking-extra-body:
        'false':
          enable_thinking: false
        'true':
          enable_thinking: true
          preserve_thinking: true
      url: https://dashscope.aliyuncs.com/compatible-mode/v1