# yaml-language-server: $schema=config.schema.json
server:
  auth_key: ur_auth_key
  port: 5212
#  cert: "certs/domain.crt"
#  key: "certs/domain.key"
  public_address: https://example.com
  log_level: DEBUG
  nginx_ready: false
  # 注意，开启后会读取X-Forwarded-For作为真实ip，会使用HTTP模式，会只允许本地连接，会限制Body大小最大为100MB，建议QQBot使用本地HTTP连接。如果必须通过Nginx连接，务必检查Body大小是否会超过100MB
  # 开启后，记得修改port。示例Nginx配置使用5212端口，反代到5213端口。public_address为用户/外部访问的地址，需使用Nginx的地址

bing_crawler:
  timeout: 10000 # timeout
  strict_anti_crawl_model: true # 是否开启严格反爬模式，模拟用户输入，会造成一次搜索花费两倍时间
  use_reversed_exa_mcp_first: false # 优先使用 Exa MCP 代理搜索，失败回退浏览器
  # exa_api_key: "" # Exa MCP API 密钥，可选

ncm:

bilibili:

VoiceRecognition:
  - type: azure
    key: xxx
    url: https://eastus.api.cognitive.microsoft.com/speechtotext/transcriptions:transcribe?api-version=2025-10-15
  - type: aliyun
    model: "paraformer-v2"
    key: sk-xxx

ocr:
  # 需要umi-ocr
  umi_ocr_endpoint: "http://127.0.0.1:1224/api/ocr"

link:

invite:
  # https://developers.cloudflare.com/turnstile/get-started/?preferred-color-scheme=dark#existing-sites
  turnstile-secret: ""
  # 无header保护，尽可能复杂
  invite-code-key: ur_key

webchat:
  default-model: "deepseek-chat"
  default-vision-model: "qwen3.5-plus" # 需要支持视觉输入
  title-model: "deepseek-chat"
  bcrypt_cost: 10 # 可选，默认10
  prompt_raw: |-
    你是一位真诚且具备适配能力的协作伙伴，略带一丝风趣。你的目标是通过富有洞见、同时清晰简洁的回复，精准回应用户的真实需求。你的核心原则是在共情与坦诚之间找到平衡：以支持性、接地气的伙伴身份，真诚认可用户的感受；同时以友善同行而非刻板说教者的姿态，温和但直接地纠正明显的错误信息。细微调整你的语气、情绪和幽默感，以适配用户的沟通风格。

    ---

    **用户区域**

    这是用户区域，根据用户自定义。你可以在回复中适度借鉴和当前问题相关的记忆，提供个性化对话体验。

    **用户记忆**：
    {memory_block}

    ---

    **现在的时间**：{time}

    ---
  models:
    deepseek-v4-flash:
      desc: "Deepseek V4 Flash"
      api_key: ur_key
      thinking-extra-body:
        'false':
          thinking:
            type: disabled
        'true':
          thinking:
            type: enabled
      url: https://api.deepseek.com/
    kimi-k2.6:
      desc: "Kimi K2.6"
      api_key: ur_key
      vision: true
      thinking-extra-body:
        'false':
          thinking:
            type: disabled
        'true':
          thinking:
            type: enabled
            keep: all
      url: https://api.moonshot.cn/v1
    qwen3.6-plus:
      desc: "Qwen3.6 Plus"
      api_key: ur_key
      vision: true
      thinking-extra-body:
        'false':
          enable_thinking: false
        'true':
          enable_thinking: true
          preserve_thinking: true
      url: https://dashscope.aliyuncs.com/compatible-mode/v1
    mimo-v2.5-pro:
      desc: "Mimo 2.5 Pro"
      api_key: ur_key
      thinking-extra-body:
        'false':
          thinking:
            type: disabled
        'true':
          thinking:
            type: enabled
      url: https://token-plan-cn.xiaomimimo.com/v1
    mimo-v2.5:
      desc: "Mimo 2.5"
      api_key: ur_key
      vision: true
      thinking-extra-body:
        'false':
          thinking:
            type: disabled
        'true':
          thinking:
            type: enabled
      url: https://token-plan-cn.xiaomimimo.com/v1
    LongCat-2.0-Preview:
      hidden: true
      api_key: xxx
      url: https://api.longcat.chat/openai